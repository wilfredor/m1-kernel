 	".pushsection .cpuidle.text, \"ax\"\n"
 	".type apple_cpu_deep_wfi, @function\n"
@@ -30,10 +47,22 @@ asm(
 		"stp x20, x21, [sp, #-16]!\n"
 		"stp x18, x19, [sp, #-16]!\n"
 
+		/* Save original ACC_OVRD for restore on wake */
+		"mrs x1, s3_5_c15_c6_0\n"
+		"str x1, [sp, #-16]!\n"
+
+		/* CYC_OVRD: WFI_MODE=3 (deep WFI) */
 		"mrs x0, s3_5_c15_c5_0\n"
 		"orr x0, x0, #(3L << 24)\n"
 		"msr s3_5_c15_c5_0, x0\n"
 
+		/* ACC_OVRD: enable deeper cluster power gating */
+		"mrs x0, s3_5_c15_c6_0\n"
+		"orr x0, x0, #(3L << 17)\n"	/* TRAIN_DOWN_LINK(3) */
+		"orr x0, x0, #(3L << 25)\n"	/* POWER_DOWN_CPM(3) */
+		"orr x0, x0, #(1L << 32)\n"	/* DISABLE_PIO_ON_WFI */
+		"msr s3_5_c15_c6_0, x0\n"
+
 	"1:\n"
 		"dsb sy\n"
 		"wfi\n"
@@ -41,6 +70,11 @@ asm(
 		"mrs x0, ISR_EL1\n"
 		"cbz x0, 1b\n"
 
+		/* Restore ACC_OVRD */
+		"ldr x1, [sp], #16\n"
+		"msr s3_5_c15_c6_0, x1\n"
+
+		/* Clear CYC_OVRD WFI_MODE */
 		"mrs x0, s3_5_c15_c5_0\n"
 		"bic x0, x0, #(1L << 24)\n"
 		"msr s3_5_c15_c5_0, x0\n"
