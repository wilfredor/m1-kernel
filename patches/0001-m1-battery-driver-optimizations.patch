@@ -77,6 +78,70 @@ struct apple_cpu_priv {
 
 static struct cpufreq_driver apple_soc_cpufreq_driver;
 
+static bool battery_aware = true;
+module_param(battery_aware, bool, 0644);
+MODULE_PARM_DESC(battery_aware, "Cap P-core frequency on battery (default: on)");
+
+static unsigned int battery_freq_pct = 80;
+module_param(battery_freq_pct, uint, 0644);
+MODULE_PARM_DESC(battery_freq_pct, "Max P-core frequency %% on battery (default: 80)");
+
+static bool on_ac_power = true;
+static struct notifier_block apple_cpufreq_psy_nb;
+
+static void apple_soc_cpufreq_update_limits(bool ac_online)
+{
+	struct cpufreq_policy *policy;
+	unsigned int cpu;
+
+	if (!battery_aware)
+		return;
+
+	on_ac_power = ac_online;
+
+	for_each_online_cpu(cpu) {
+		policy = cpufreq_cpu_get(cpu);
+		if (!policy)
+			continue;
+
+		/*
+		 * Only cap P-cores (policy4+). E-cores (policy0) are already
+		 * efficient and should not be limited.
+		 */
+		if (cpumask_first(policy->cpus) >= 4) {
+			if (ac_online) {
+				policy->max = policy->cpuinfo.max_freq;
+			} else {
+				policy->max = policy->cpuinfo.max_freq *
+					      battery_freq_pct / 100;
+			}
+			cpufreq_update_limits(cpu);
+		}
+		cpufreq_cpu_put(policy);
+	}
+}
